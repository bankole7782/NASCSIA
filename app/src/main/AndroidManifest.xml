<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NASCSIA">
        <activity
            android:name=".pplans.PPlanPhotosActivity"
            android:exported="false"
            android:label="@string/title_activity_pplan_photos"
            android:theme="@style/Theme.NASCSIA" />
        <activity
            android:name=".pplans.ProductionPlanViewActivity"
            android:exported="false"
            android:label="@string/title_activity_production_plan_view"
            android:theme="@style/Theme.NASCSIA" />
        <activity
            android:name=".pplans.ProductionPlanActivity"
            android:exported="false"
            android:label="@string/title_activity_fields"
            android:theme="@style/Theme.NASCSIA" />
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:label="@string/title_activity_login_screen"
            android:theme="@style/Theme.NASCSIA" />
        <activity
            android:name=".pplans.SeedSourceActivity"
            android:exported="false"
            android:label="@string/title_activity_seed_source"
            android:theme="@style/Theme.NASCSIA" />
        <activity
            android:name=".pplans.CropInformationActivity"
            android:exported="false"
            android:label="@string/title_activity_crop_information"
            android:theme="@style/Theme.NASCSIA" />
        <activity
            android:name=".pplans.FieldLocationActivity"
            android:exported="false"
            android:label="@string/title_activity_field_location"
            android:theme="@style/Theme.NASCSIA" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.NASCSIA">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>